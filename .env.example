# ─── Solana RPC ───────────────────────────────────────
# Primary: Get free key at https://dev.helius.xyz
VITE_HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY_HERE
HELIUS_API_KEY=your_helius_api_key

SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_KEY=your_service_key
API_SECRET=your_internal_secret

# Fallback (rate-limited but always works)
VITE_SOLANA_FALLBACK_RPC=https://api.mainnet-beta.solana.com

# ─── Firebase ─────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ─── App Config ───────────────────────────────────────
# Treasury wallet that receives service fees
VITE_TREASURY_WALLET=DD4AdYKVcV6kgpmiCEeASRmJyRdKgmaRAbsjKucx8CvY

# Service fee in SOL (shown to user before they sign)
VITE_SERVICE_FEE_SOL=0.01

# Jupiter API key (recommended for Engine 3 swap routing; get from portal.jup.ag)
VITE_JUP_API_KEY=

# App environment (development | production)
VITE_APP_ENV=development
